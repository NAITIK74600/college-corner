# ─── College Corner — Local Print Client ─────────────────────────────────────
# Copy this file to .env and fill in your values.

# URL of the CC backend API
API_URL=http://localhost:5000

# API key — must match PRINT_CLIENT_API_KEY in backend/.env
PRINT_CLIENT_API_KEY=cc_print_dev_key_2026

# The unique printer ID from the admin dashboard (Printers tab → copy the UUID)
PRINTER_ID=your-printer-uuid-here

# The exact Windows printer name shown in Control Panel → Devices and Printers
# Leave blank to use the system default printer
PRINTER_NAME=

# How often to poll the backend for new jobs (milliseconds)
POLL_INTERVAL_MS=5000
